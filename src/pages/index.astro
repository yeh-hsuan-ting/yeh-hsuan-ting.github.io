---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';

// Drafts are visible while running `astro dev` (handy for previewing),
// but excluded from `astro build` output.
const posts = (
  await getCollection('posts', ({ data }) => import.meta.env.DEV || !data.draft)
).sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());

const fmt = (d: Date) =>
  d.toLocaleDateString('zh-TW', { year: 'numeric', month: 'long', day: 'numeric' });
---

<Base title={SITE_TITLE} description={SITE_DESCRIPTION}>
  <ul class="flex flex-col">
    {
      posts.map((post) => (
        <li class="border-b border-rule">
          <a href={`/posts/${post.id}/`} class="group block py-6 text-fg no-underline">
            <div class="flex flex-wrap items-baseline justify-between gap-x-4 gap-y-1">
              <span class="text-lg group-hover:underline">
                {post.data.title}
                {post.data.draft && (
                  <span class="label ml-2 border border-rule px-1.5 py-0.5 align-middle text-[0.6rem]">
                    草稿
                  </span>
                )}
              </span>
              <time
                datetime={post.data.pubDate.toISOString()}
                class="label whitespace-nowrap"
              >
                {fmt(post.data.pubDate)}
              </time>
            </div>
            {post.data.description && <p class="mt-1 text-muted">{post.data.description}</p>}
          </a>
        </li>
      ))
    }
  </ul>
</Base>
