---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';

// Drafts are visible while running `astro dev` (handy for previewing),
// but excluded from `astro build` output.
const posts = (
  await getCollection('posts', ({ data }) => import.meta.env.DEV || !data.draft)
).sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());

const fmt = (d: Date) =>
  d.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
---

<Base title={SITE_TITLE} description={SITE_DESCRIPTION}>
  <ul class="post-list">
    {
      posts.map((post) => (
        <li>
          <a href={`/posts/${post.id}/`}>
            <span class="post-list-title">
              {post.data.title}
              {post.data.draft && <span class="draft-tag">draft</span>}
            </span>
            <time datetime={post.data.pubDate.toISOString()}>{fmt(post.data.pubDate)}</time>
          </a>
          {post.data.description && <p class="post-list-desc">{post.data.description}</p>}
        </li>
      ))
    }
  </ul>
</Base>
